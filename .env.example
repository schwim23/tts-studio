# ---------------------------------------------------------------------------
# TTS Studio works with NO configuration at all (edge-tts, keyless).
# Everything below is OPTIONAL and only unlocks the Google Cloud TTS upgrade.
# ---------------------------------------------------------------------------

# Option A: path to a Google Cloud service-account JSON file (local dev).
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Option B: the service-account JSON inlined as a single string (cloud hosting,
# e.g. paste into Streamlit secrets). Takes effect if Option A is not set.
# GOOGLE_TTS_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Hard cap on input characters accepted by the app (protects public deploys).
# TTS_MAX_INPUT_CHARS=50000
